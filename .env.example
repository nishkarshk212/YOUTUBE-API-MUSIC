# API Configuration
API_KEY=your_secure_api_key_here
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=YouTube API Service
API_VERSION=1.0.0

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Caching Configuration
CACHE_ENABLED=true
CACHE_TYPE=memory
CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0

# YouTube Configuration
YTDLP_AUTO_UPDATE=true
DEFAULT_AUDIO_FORMAT=bestaudio/best
DEFAULT_VIDEO_FORMAT=bestvideo+bestaudio/best
MAX_RESULTS=10
REGION_FALLBACK=true

# Enhanced Extraction Settings
USE_COOKIES=false
COOKIE_FILE=
SOURCE_ADDRESS=0.0.0.0
ENABLE_IPV4=true
MAX_RETRIES=3
RETRY_DELAY=1

# Client Fallback Order (comma-separated)
CLIENT_ORDER=android,web,ios,tv

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ALLOWED_ORIGINS=*
